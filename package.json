{
  "name": "volunteer",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.46.0",
    "@payloadcms/next": "3.46.0",
    "@payloadcms/payload-cloud": "3.46.0",
    "@payloadcms/plugin-cloud-storage": "3.46.0",
    "@payloadcms/richtext-lexical": "3.46.0",
    "@payloadcms/storage-vercel-blob": "^3.46.0",
    "@payloadcms/ui": "3.46.0",
    "@turf/turf": "^7.2.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "escape-html": "^1.0.3",
    "feedparser": "^2.2.10",
    "graphql": "^16.11.0",
    "leaflet": "^1.9.4",
    "next": "15.3.2",
    "next-recaptcha-v3": "^1.5.2",
    "nextjs-toploader": "^3.8.16",
    "payload": "3.46.0",
    "react": "19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-leaflet": "^5.0.0",
    "react-phone-input-2": "^2.15.1",
    "react-phone-number-input": "^3.4.12",
    "react-vertical-timeline-component": "^3.5.3",
    "recharts": "^3.1.0",
    "rss-to-json": "^2.1.1",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@playwright/test": "1.50.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^22.16.2",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.2",
    "@types/react-vertical-timeline-component": "^3.3.6",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-config-next": "15.3.0",
    "jsdom": "26.1.0",
    "playwright": "1.50.0",
    "playwright-core": "1.50.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  }
}
